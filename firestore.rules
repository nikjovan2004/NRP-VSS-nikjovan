rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Za razvoj: prijavljeni uporabnik lahko bere/piše vse
    // Collections: users, providers, providerSlots, orders, reviews, notifications, favorites, alerts
    // Subcollection: orders/{orderId}/messages (chat)
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
